# ─── Google Ads OAuth2 ────────────────────────────────────────────────────────
# Get these from Google Cloud Console → APIs & Services → Credentials
GADS_CLIENT_ID=your-client-id.apps.googleusercontent.com
GADS_CLIENT_SECRET=your-client-secret

# Refresh token from OAuth2 flow (see README for how to generate this)
GADS_REFRESH_TOKEN=your-refresh-token

# ─── Google Ads API ───────────────────────────────────────────────────────────
# Apply at: https://developers.google.com/google-ads/api/docs/get-started/dev-token
GADS_DEVELOPER_TOKEN=your-developer-token

# Your Google Ads Customer ID (10 digits, no hyphens)
GADS_CUSTOMER_ID=1234567890

# Optional: If you're accessing a client account via a Manager (MCC) account
# GADS_LOGIN_CUSTOMER_ID=9876543210
